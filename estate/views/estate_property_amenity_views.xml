<odoo>
    <record id="estate_property_amenity_action" model="ir.actions.act_window">
        <field name="name">Amenities</field>
        <field name="res_model">estate.property.amenity</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="estate_property_amenity_view_list" model="ir.ui.view">
        <field name="name">estate.property.amenity.list</field>
        <field name="model">estate.property.amenity</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="category"/>
            </list>
        </field>
    </record>

    <record id="estate_property_amenity_view_search" model="ir.ui.view">
        <field name="name">estate.property.amenity.search</field>
        <field name="model">estate.property.amenity</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <group>
                    <filter name="group_category" string="Category"
                            context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
