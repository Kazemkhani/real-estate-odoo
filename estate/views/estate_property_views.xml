<odoo>
    <record id="estate_property_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">kanban,list,form,graph,pivot</field>
    </record>

    <!-- LIST: rows colored by status -->
    <record id="estate_property_view_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list decoration-success="state in ('offer_received', 'offer_accepted')"
                  decoration-bf="state == 'offer_accepted'"
                  decoration-muted="state == 'sold'">
                <field name="name"/>
                <field name="property_type_id"/>
                <field name="postcode"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="bedrooms"/>
                <field name="living_area"/>
                <field name="expected_price"/>
                <field name="selling_price"/>
                <field name="date_availability" optional="hide"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- FORM: header buttons + statusbar + tabs -->
    <record id="estate_property_view_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="sell_property" type="object" string="Sell"
                            invisible="state in ('sold', 'cancelled')"/>
                    <button name="action_make_offer" type="object" string="Make an Offer"
                            class="btn-secondary"
                            invisible="state in ('sold', 'cancelled')"/>
                    <button name="cancel_property" type="object" string="Cancel"
                            invisible="state in ('sold', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,offer_accepted,sold"
                           invisible="state == 'cancelled'"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Cancelled" bg_color="bg-danger"
                            invisible="state != 'cancelled'"/>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_offers" icon="fa-money">
                            <field name="offer_count" widget="statinfo" string="Offers"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <h1><field name="name" placeholder="Property name..."/></h1>
                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                    <group>
                        <group>
                            <field name="property_type_id"/>
                            <field name="postcode"/>
                            <field name="date_availability"/>
                        </group>
                        <group>
                            <field name="expected_price"/>
                            <field name="best_price"/>
                            <field name="selling_price"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <group>
                                <field name="description"/>
                                <field name="bedrooms"/>
                                <field name="living_area"/>
                                <field name="facades"/>
                                <field name="garage"/>
                                <field name="has_garden"/>
                                <field name="garden_area"/>
                                <field name="garden_orientation"/>
                                <field name="total_area"/>
                            </group>
                        </page>
                        <page string="Amenities">
                            <field name="amenity_ids" widget="many2many_checkboxes"/>
                        </page>
                        <page string="Offers">
                            <field name="offer_ids"/>
                        </page>
                        <page string="Other Info">
                            <group>
                                <field name="salesperson_id"/>
                                <field name="buyer_id"/>
                            </group>
                            <group string="Location">
                                <!-- country_flag is a Char(related="country_id.image_url").
                                     widget="image_url" renders it as an <img>.
                                     Pattern from website.visitor form (Odoo 19 core). -->
                                <div class="float-end" invisible="not country_id">
                                    <field name="country_flag" widget="image_url" options='{"size": [32, 32]}'/>
                                </div>
                                <field name="country_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- SEARCH: filters + group by -->
    <record id="estate_property_view_search" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="postcode"/>
                <field name="property_type_id"/>
                <field name="bedrooms"/>
                <field name="country_id"/>
                <filter name="available" string="Available"
                        domain="[('state', 'in', ['new', 'offer_received'])]"/>
                <group>
                    <filter name="group_type" string="Property Type"
                            context="{'group_by': 'property_type_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_country" string="Country"
                            context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- KANBAN: visual property cards grouped by type -->
    <record id="estate_property_view_kanban" model="ir.ui.view">
        <field name="name">estate.property.kanban</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <!-- class="o_estate_kanban" is the scope anchor for estate_kanban.scss -->
            <kanban default_group_by="property_type_id" sample="1" class="o_estate_kanban">
                <field name="state"/>
                <field name="currency_id"/>
                <!-- Declare country_id and country_flag so they are fetched in the
                     kanban RPC. country_flag is a related Char(country_id.image_url);
                     widget="image_url" renders a Char URL as a real <img> tag.
                     Pattern from website.visitor kanban (Odoo 19 core). -->
                <field name="country_id"/>
                <field name="country_flag"/>
                <templates>
                    <t t-name="card" class="flex-row">
                        <aside class="d-flex align-items-center me-2">
                            <field name="image_128" widget="image" options="{'img_class': 'object-fit-cover'}"/>
                        </aside>
                        <main>
                            <widget name="web_ribbon" title="Sold" bg_color="text-bg-success"
                                    invisible="state != 'sold'"/>
                            <widget name="web_ribbon" title="Cancelled" bg_color="text-bg-danger"
                                    invisible="state != 'cancelled'"/>
                            <field name="name" class="fw-bold fs-5"/>
                            <field name="property_type_id" class="text-muted"/>
                            <div class="o_estate_price_expected d-flex gap-2">
                                <span class="text-muted">Expected:</span>
                                <field name="expected_price" widget="monetary"/>
                            </div>
                            <div class="o_estate_price_selling d-flex gap-2" invisible="not selling_price">
                                <span class="text-muted">Selling:</span>
                                <field name="selling_price" widget="monetary"/>
                            </div>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <!-- Country flag row: hidden when no country set.
                                 Guards on both country_id AND country_flag to match
                                 Odoo 19 core (website.visitor kanban) sample-data safety. -->
                            <div class="o_estate_country_flag" invisible="not country_id">
                                <field name="country_flag" widget="image_url" options='{"size": [18, 18]}'/>
                                <field name="country_id" readonly="1"/>
                            </div>
                            <footer class="pt-1">
                                <field name="state" widget="badge"
                                       decoration-info="state == 'new'"
                                       decoration-warning="state == 'offer_received'"
                                       decoration-success="state in ('offer_accepted','sold')"
                                       decoration-danger="state == 'cancelled'"/>
                                <div class="ms-auto text-muted">
                                    <field name="bedrooms"/><span> bd</span>
                                </div>
                            </footer>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- GRAPH: portfolio analytics -->
    <record id="estate_property_view_graph" model="ir.ui.view">
        <field name="name">estate.property.graph</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <graph string="Properties" sample="1">
                <field name="property_type_id"/>
                <field name="expected_price" type="measure"/>
                <field name="selling_price" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- PIVOT: cross-tab analysis -->
    <record id="estate_property_view_pivot" model="ir.ui.view">
        <field name="name">estate.property.pivot</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <pivot string="Properties" sample="1">
                <field name="property_type_id" type="row"/>
                <field name="bedrooms" type="col"/>
                <field name="expected_price" type="measure"/>
                <field name="selling_price" type="measure"/>
            </pivot>
        </field>
    </record>
</odoo>
