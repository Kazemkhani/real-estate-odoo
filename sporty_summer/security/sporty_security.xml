<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Settings category -->
    <record model="ir.module.category" id="module_category_sporty">
        <field name="name">Sporty Summer</field>
        <field name="sequence">65</field>
    </record>

    <!-- Privilege (Odoo 19 requires this between category and groups) -->
    <record model="res.groups.privilege" id="res_groups_privilege_sporty">
        <field name="name">Sporty Summer</field>
        <field name="sequence">10</field>
        <field name="category_id" ref="module_category_sporty"/>
    </record>

    <!-- Staff: reception / front-desk operators -->
    <record id="group_sporty_staff" model="res.groups">
        <field name="name">Staff</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_sporty"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Manager: implies Staff; admin is a Manager so the demo keeps full access -->
    <record id="group_sporty_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_sporty"/>
        <field name="implied_ids" eval="[(4, ref('group_sporty_staff'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
