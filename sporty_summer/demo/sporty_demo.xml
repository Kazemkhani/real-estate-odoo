<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ============ Sports (with per-session participant limits) ============ -->
        <record id="sport_tennis" model="sport.type">
            <field name="name">Tennis</field>
            <field name="code">TEN</field>
            <field name="max_participants">4</field>
            <field name="default_duration">1.0</field>
            <field name="color">4</field>
        </record>
        <record id="sport_padel" model="sport.type">
            <field name="name">Padel</field>
            <field name="code">PAD</field>
            <field name="max_participants">4</field>
            <field name="default_duration">1.5</field>
            <field name="color">10</field>
        </record>
        <record id="sport_football" model="sport.type">
            <field name="name">Football</field>
            <field name="code">FOO</field>
            <field name="max_participants">14</field>
            <field name="default_duration">1.5</field>
            <field name="color">7</field>
        </record>
        <record id="sport_basketball" model="sport.type">
            <field name="name">Basketball</field>
            <field name="code">BAS</field>
            <field name="max_participants">10</field>
            <field name="default_duration">1.0</field>
            <field name="color">2</field>
        </record>

        <!-- ============ Courts ============ -->
        <record id="court_tennis_a" model="sport.court">
            <field name="name">Tennis Court A</field>
            <field name="sport_type_id" ref="sport_tennis"/>
            <field name="hourly_price">80</field>
        </record>
        <record id="court_padel_1" model="sport.court">
            <field name="name">Padel Court 1</field>
            <field name="sport_type_id" ref="sport_padel"/>
            <field name="hourly_price">100</field>
        </record>
        <record id="court_football" model="sport.court">
            <field name="name">Football Pitch</field>
            <field name="sport_type_id" ref="sport_football"/>
            <field name="hourly_price">200</field>
        </record>
        <record id="court_basketball" model="sport.court">
            <field name="name">Basketball Court</field>
            <field name="sport_type_id" ref="sport_basketball"/>
            <field name="hourly_price">120</field>
        </record>

        <!-- ============ People ============ -->
        <record id="customer_ahmed" model="res.partner">
            <field name="name">Ahmed Al Mansoori</field>
            <field name="email">ahmed@example.com</field>
        </record>
        <record id="customer_layla" model="res.partner">
            <field name="name">Layla Hassan</field>
            <field name="email">layla@example.com</field>
        </record>
        <record id="customer_omar" model="res.partner">
            <field name="name">Omar Said</field>
            <field name="email">omar@example.com</field>
        </record>
        <record id="customer_sara" model="res.partner">
            <field name="name">Sara Khan</field>
            <field name="email">sara@example.com</field>
        </record>
        <record id="coach_khalid" model="res.partner">
            <field name="name">Coach Khalid</field>
            <field name="is_coach" eval="True"/>
        </record>
        <record id="coach_mariam" model="res.partner">
            <field name="name">Coach Mariam</field>
            <field name="is_coach" eval="True"/>
        </record>

        <!-- ============ Bookings (distinct slots — no court overlaps) ============ -->
        <record id="booking_1" model="sport.booking">
            <field name="court_id" ref="court_tennis_a"/>
            <field name="customer_id" ref="customer_ahmed"/>
            <field name="start_datetime">2026-07-01 08:00:00</field>
            <field name="end_datetime">2026-07-01 09:00:00</field>
            <field name="participant_count">2</field>
            <field name="state">paid</field>
        </record>
        <record id="booking_2" model="sport.booking">
            <field name="court_id" ref="court_tennis_a"/>
            <field name="customer_id" ref="customer_layla"/>
            <field name="start_datetime">2026-07-01 09:00:00</field>
            <field name="end_datetime">2026-07-01 10:00:00</field>
            <field name="participant_count">4</field>
            <field name="state">confirmed</field>
        </record>
        <record id="booking_3" model="sport.booking">
            <field name="court_id" ref="court_padel_1"/>
            <field name="customer_id" ref="customer_omar"/>
            <field name="start_datetime">2026-07-02 18:00:00</field>
            <field name="end_datetime">2026-07-02 19:30:00</field>
            <field name="participant_count">4</field>
            <field name="state">draft</field>
        </record>
        <record id="booking_4" model="sport.booking">
            <field name="court_id" ref="court_football"/>
            <field name="customer_id" ref="customer_sara"/>
            <field name="start_datetime">2026-07-03 17:00:00</field>
            <field name="end_datetime">2026-07-03 18:30:00</field>
            <field name="participant_count">12</field>
            <field name="state">done</field>
        </record>
        <record id="booking_5" model="sport.booking">
            <field name="court_id" ref="court_basketball"/>
            <field name="customer_id" ref="customer_ahmed"/>
            <field name="start_datetime">2026-07-03 19:00:00</field>
            <field name="end_datetime">2026-07-03 20:00:00</field>
            <field name="participant_count">8</field>
            <field name="state">paid</field>
        </record>

        <!-- ============ Coaching classes ============ -->
        <record id="class_tennis_junior" model="sport.coaching.class">
            <field name="name">Junior Tennis Camp</field>
            <field name="sport_type_id" ref="sport_tennis"/>
            <field name="coach_id" ref="coach_khalid"/>
            <field name="schedule">Mon &amp; Wed, 17:00–18:00</field>
            <field name="start_date">2026-07-06</field>
            <field name="end_date">2026-08-14</field>
            <field name="price">250</field>
            <field name="capacity">8</field>
            <field name="state">open</field>
        </record>
        <record id="class_padel_beginner" model="sport.coaching.class">
            <field name="name">Padel for Beginners</field>
            <field name="sport_type_id" ref="sport_padel"/>
            <field name="coach_id" ref="coach_mariam"/>
            <field name="schedule">Tue &amp; Thu, 19:00–20:00</field>
            <field name="start_date">2026-07-07</field>
            <field name="price">300</field>
            <field name="capacity">6</field>
            <field name="state">open</field>
        </record>

        <!-- ============ Registrations (first-come, first-served) ============ -->
        <record id="reg_1" model="sport.class.registration">
            <field name="class_id" ref="class_tennis_junior"/>
            <field name="customer_id" ref="customer_ahmed"/>
            <field name="state">paid</field>
        </record>
        <record id="reg_2" model="sport.class.registration">
            <field name="class_id" ref="class_tennis_junior"/>
            <field name="customer_id" ref="customer_layla"/>
            <field name="state">confirmed</field>
        </record>
        <record id="reg_3" model="sport.class.registration">
            <field name="class_id" ref="class_padel_beginner"/>
            <field name="customer_id" ref="customer_sara"/>
            <field name="state">paid</field>
        </record>

        <!-- ============ Equipment + loans ============ -->
        <record id="equipment_tennis_racket" model="sport.equipment">
            <field name="name">Tennis Racket</field>
            <field name="code">EQ-TEN-RKT</field>
            <field name="sport_type_id" ref="sport_tennis"/>
            <field name="total_quantity">10</field>
        </record>
        <record id="equipment_football" model="sport.equipment">
            <field name="name">Football</field>
            <field name="code">EQ-FOO-BALL</field>
            <field name="sport_type_id" ref="sport_football"/>
            <field name="total_quantity">20</field>
        </record>
        <record id="equipment_padel_racket" model="sport.equipment">
            <field name="name">Padel Racket</field>
            <field name="code">EQ-PAD-RKT</field>
            <field name="sport_type_id" ref="sport_padel"/>
            <field name="total_quantity">8</field>
        </record>

        <record id="loan_1" model="sport.equipment.loan">
            <field name="equipment_id" ref="equipment_tennis_racket"/>
            <field name="customer_id" ref="customer_ahmed"/>
            <field name="booking_id" ref="booking_1"/>
            <field name="quantity">2</field>
            <field name="state">loaned</field>
        </record>
        <record id="loan_2" model="sport.equipment.loan">
            <field name="equipment_id" ref="equipment_tennis_racket"/>
            <field name="customer_id" ref="customer_layla"/>
            <field name="quantity">1</field>
            <field name="state">returned</field>
        </record>
        <record id="loan_3" model="sport.equipment.loan">
            <field name="equipment_id" ref="equipment_football"/>
            <field name="customer_id" ref="customer_sara"/>
            <field name="booking_id" ref="booking_4"/>
            <field name="quantity">1</field>
            <field name="state">loaned</field>
        </record>
    </data>
</odoo>
