<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sport_court_action" model="ir.actions.act_window">
        <field name="name">Courts</field>
        <field name="res_model">sport.court</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <record id="sport_court_view_list" model="ir.ui.view">
        <field name="name">sport.court.list</field>
        <field name="model">sport.court</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'maintenance'">
                <field name="name"/>
                <field name="sport_type_id"/>
                <field name="max_participants"/>
                <field name="hourly_price"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="sport_court_view_kanban" model="ir.ui.view">
        <field name="name">sport.court.kanban</field>
        <field name="model">sport.court</field>
        <field name="arch" type="xml">
            <kanban default_group_by="sport_type_id" sample="1">
                <field name="state"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <widget name="web_ribbon" title="Maintenance" bg_color="text-bg-warning"
                                invisible="state != 'maintenance'"/>
                        <div class="fw-bold fs-5"><field name="name"/></div>
                        <field name="sport_type_id" class="text-muted"/>
                        <div class="d-flex justify-content-between mt-2">
                            <span><i class="fa fa-users me-1"/><field name="max_participants"/> max</span>
                            <field name="hourly_price" widget="monetary"/>
                        </div>
                        <footer>
                            <button name="action_view_bookings" type="object" class="btn btn-sm btn-link ps-0">
                                <i class="fa fa-calendar me-1"/><field name="booking_count"/> bookings
                            </button>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="sport_court_view_form" model="ir.ui.view">
        <field name="name">sport.court.form</field>
        <field name="model">sport.court</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_bookings" icon="fa-calendar">
                            <field name="booking_count" widget="statinfo" string="Bookings"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Center Court"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="sport_type_id"/>
                            <field name="max_participants"/>
                        </group>
                        <group>
                            <field name="hourly_price" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="state"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
