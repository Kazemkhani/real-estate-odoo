<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sport_equipment_loan_action" model="ir.actions.act_window">
        <field name="name">Equipment Loans</field>
        <field name="res_model">sport.equipment.loan</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <record id="sport_equipment_loan_view_list" model="ir.ui.view">
        <field name="name">sport.equipment.loan.list</field>
        <field name="model">sport.equipment.loan</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'loaned'"
                  decoration-success="state == 'returned'"
                  decoration-danger="state in ('lost', 'damaged')">
                <field name="name"/>
                <field name="equipment_id"/>
                <field name="customer_id"/>
                <field name="quantity"/>
                <field name="loan_date"/>
                <field name="return_date"/>
                <field name="penalty_amount" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"/>
                <button name="action_return" type="object" string="Return" icon="fa-undo"
                        invisible="state != 'loaned'"/>
            </list>
        </field>
    </record>

    <record id="sport_equipment_loan_view_kanban" model="ir.ui.view">
        <field name="name">sport.equipment.loan.kanban</field>
        <field name="model">sport.equipment.loan</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1">
                <field name="state"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="fw-bold"><field name="name"/></div>
                        <field name="equipment_id"/>
                        <div class="text-muted"><field name="customer_id"/></div>
                        <div class="mt-1"><i class="fa fa-cubes me-1"/>Qty: <field name="quantity"/></div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="sport_equipment_loan_view_form" model="ir.ui.view">
        <field name="name">sport.equipment.loan.form</field>
        <field name="model">sport.equipment.loan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_return" type="object" string="Mark Returned"
                            class="btn-primary" invisible="state != 'loaned'"/>
                    <button name="action_mark_lost" type="object" string="Mark Lost"
                            invisible="state != 'loaned'"/>
                    <button name="action_mark_damaged" type="object" string="Mark Damaged"
                            invisible="state != 'loaned'"/>
                    <field name="state" widget="statusbar" statusbar_visible="loaned,returned"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="equipment_id"/>
                            <field name="customer_id"/>
                            <field name="booking_id"/>
                            <field name="quantity"/>
                        </group>
                        <group>
                            <field name="loan_date"/>
                            <field name="return_date"/>
                            <field name="penalty_amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Condition notes, damage details..."/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
