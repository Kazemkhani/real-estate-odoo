<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sport_equipment_action" model="ir.actions.act_window">
        <field name="name">Equipment</field>
        <field name="res_model">sport.equipment</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="sport_equipment_view_list" model="ir.ui.view">
        <field name="name">sport.equipment.list</field>
        <field name="model">sport.equipment</field>
        <field name="arch" type="xml">
            <list decoration-danger="available_quantity &lt;= 0">
                <field name="name"/>
                <field name="sport_type_id"/>
                <field name="total_quantity"/>
                <field name="loaned_quantity"/>
                <field name="lost_quantity"/>
                <field name="available_quantity"/>
            </list>
        </field>
    </record>

    <record id="sport_equipment_view_form" model="ir.ui.view">
        <field name="name">sport.equipment.form</field>
        <field name="model">sport.equipment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name" placeholder="e.g. Tennis Racket"/></h1></div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sport_type_id"/>
                            <field name="total_quantity"/>
                        </group>
                        <group>
                            <field name="loaned_quantity"/>
                            <field name="lost_quantity"/>
                            <field name="available_quantity"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Loans">
                            <field name="loan_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="customer_id"/>
                                    <field name="quantity"/>
                                    <field name="loan_date"/>
                                    <field name="return_date"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
