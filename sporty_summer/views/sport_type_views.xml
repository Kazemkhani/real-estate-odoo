<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sport_type_action" model="ir.actions.act_window">
        <field name="name">Sports</field>
        <field name="res_model">sport.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="sport_type_view_list" model="ir.ui.view">
        <field name="name">sport.type.list</field>
        <field name="model">sport.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="max_participants"/>
                <field name="default_duration"/>
            </list>
        </field>
    </record>

    <record id="sport_type_view_form" model="ir.ui.view">
        <field name="name">sport.type.form</field>
        <field name="model">sport.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Tennis"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="max_participants"/>
                            <field name="default_duration"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="court_ids">
                        <list>
                            <field name="name"/>
                            <field name="hourly_price"/>
                            <field name="state"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
